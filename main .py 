import tkinter as tk 
from tkinter import messagebox
import datetime # I used "datetime" library only for time . 
def save_data ( ) : 
        amount = expense_entry .get ( ) # Extract amount from the entry box . 
        if amount == "" : # If the box empty 
            messagebox .showwarning ( "      Error     " , " please enter an amount " ) 
        else : 
            # Capture the accurate date and time      
            now = datetime.datetime.now ( )  
            present_date_time = now .strftime ( " %d-%m-%Y, %H:%M:%S " ) 
            # open the file in append move to save data 
            try : 
                with open( " expense .txt " , "a" ) as file :   
                    file .write ( f" Your amount :  { present_date_time } | { amount } \n " ) 
                    # showed success message to the users 
                    messagebox .showinfo ( "     Successful   " ) 
                    # clear the entry box after successful save 
                    expense_entry .delete ( 0 , 'end' ) 
            except Exception as e : 
                messagebox .showerror ( " File error ", " Could not save data : { e } " ) 
# …UI setup… 
root = tk .Tk ( ) 
root .title ( " Tahmid's Eid app " ) 
root . geometry ("300x350") 
# Header level 
label = tk .Label ( root , text = " Enter your amount : " , font = ( " Arial ", 15, " bold " ) ) 
label .pack ( pady = 15 ) 
# Entry users 
expense_entry = tk .Entry ( root ) 
expense_entry .pack ( pady = 10 ) 
# Professional Blue button along with command button 
save_button = tk .Button ( root , text = " save expense " , bg = "blue", fg = "white", font = ( " Arial ", 11, " bold " ) ,  command = save_data ) 
save_button .pack ( pady = 25 ) 
# start the application 
root .mainloop ( ) 