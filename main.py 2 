import tkinter as tk 
from tkinter import messagebox
import datetime # I used "datetime" library only for time . 
def save_data ( ) : 
        amount = expense_entry .get ( ) # Extract amount from the entry box . 
        current_category = select_cat .get ( ) #  From dropdown , user's choice take hand '  
        if amount == "" : # If the box empty 
            messagebox .showwarning ( "      Error     " , " please enter an amount " ) 
        else : 
            # Capture the accurate date and time      
            now = datetime.datetime.now ( )  
            present_date_time = now .strftime ( " %d-%m-%Y, %H:%M:%S " ) 
            # open the file in append move to save data 
            try : 
                with open( " expense .txt " , "a" ) as file :   
                    file .write ( f" Your amount :  { present_date_time } | { amount } | { current_category } \n " ) 
                    # showed success message to the users 
                    messagebox .showinfo ( "     Successful   " ) 
                    # clear the entry box after successful save 
                    expense_entry .delete ( 0 , 'end' ) 
            except Exception as e : 
                messagebox .showerror ( " File error ", " Could not save data : { e } " ) 
def show_total ( ) : 
        total = 0 
        amounts = [ ] 
        try : 
            with open ( " expense .txt ", "r" ) as file : 
                lines = file .readlines ( ) 
                for line in lines : 
                    parts = line .split ( " | " ) 
                    if len ( parts ) >= 2 : 
                        my_amount = parts [ 1 ] .strip ( ) 
                        total += float ( my_amount ) 
            messagebox .showinfo ( " Total expenses : ", f" Total cost is : { total } BDT " ) 
        except FileNotFoundError : 
            messagebox . showerror ( " Error ", " No expense data found ! " )                                             
